# This .gitignore file should be placed at the root of your Unity project

/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# MemoryCaptures can get excessive in size
/[Mm]emoryCaptures/

# Asset meta data should only be ignored when the corresponding asset is ignored
!/[Aa]ssets/**/*.meta
!/[Pp]ackages/**/*.meta
!/[Pp]roject[Ss]ettings/**/*.meta

# Visual Studio cache directory
.vs/

# Visual Studio generated files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Rider
.idea/
*.sln.iml

# VS Code
.vscode/

# Gradle cache
.gradle/

# Auto-generated Android files
*.apk
*.aab

# Crash reports
sysinfo.txt

# Unity generated files
*.stacktrace

# Addressables
/ServerData/

# Generated documentation
Documentation~

# Test results
TestResults/

# Unity Cloud Build
build/